API_HOST=127.0.0.1
API_PORT=3001
STEP_DURATION_MS=1300

# Provider routing: mock, local, or openai. If empty, the backend uses local
# when LOCAL_LLM_BASE_URL is configured, otherwise OpenAI when OPENAI_API_KEY is
# configured, otherwise mock.
LLM_PROVIDER=

# Local OpenAI-compatible endpoint. For Ollama, use:
# LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# For vLLM, use the /v1 endpoint exposed by your server.
LOCAL_LLM_BASE_URL=
LOCAL_LLM_API_KEY=local-dev
LOCAL_LLM_DEFAULT_MODEL=Phi-4-mini-instruct
LOCAL_LLM_REASONING_MODEL=Qwen3.6-27B
LOCAL_LLM_CODER_MODEL=Qwen3-Coder-Next

# Local model routing. Keep these on local for the cost-efficient default plan.
BA_AGENT_PROVIDER=local
ARCHITECT_AGENT_PROVIDER=local
SOFTWARE_AGENT_PROVIDER=local
TESTER_AGENT_PROVIDER=local
DEVOPS_AGENT_PROVIDER=local
BA_AGENT_LOCAL_MODEL=Qwen3.6-27B
ARCHITECT_AGENT_LOCAL_MODEL=Qwen3.6-27B
SOFTWARE_AGENT_LOCAL_MODEL=Qwen3-Coder-Next
TESTER_AGENT_LOCAL_MODEL=Qwen3.6-27B
DEVOPS_AGENT_LOCAL_MODEL=Qwen3.6-27B

# Create an API key in the OpenAI dashboard and put the real value in .env.
# This is the approved paid fallback for hard cases.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
BA_AGENT_OPENAI_MODEL=gpt-5.4-mini
ARCHITECT_AGENT_OPENAI_MODEL=gpt-5.4-mini
SOFTWARE_AGENT_OPENAI_MODEL=gpt-5.4-mini
TESTER_AGENT_OPENAI_MODEL=gpt-5.4-mini
DEVOPS_AGENT_OPENAI_MODEL=gpt-5.4-mini
LLM_REQUIRE_APPROVAL=true
LLM_MAX_OUTPUT_TOKENS=300
CONTEXT_FILE_LIMIT=6
CONTEXT_FILE_MAX_BYTES=5242880
